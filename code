import os
import xml.etree.ElementTree as ET

# Paths
image_dir = "/content/gun_dataset/adithya_gun data_set/images"
annotations_dir = "/content/gun_dataset/adithya_gun data_set/annotations"
labels_dir = "/content/gun_dataset/adithya_gun data_set/labels"

# Create labels/train and labels/val
os.makedirs(f"{labels_dir}/train", exist_ok=True)
os.makedirs(f"{labels_dir}/val", exist_ok=True)

def convert_voc_to_yolo(xml_file, output_txt, image_size):
    tree = ET.parse(xml_file)
    root = tree.getroot()

    width = int(root.find("size/width").text)
    height = int(root.find("size/height").text)

    with open(output_txt, "w") as f:
        for obj in root.findall("object"):
            name = obj.find("name").text
            if name.lower() != "gun":
                continue  # skip unknown classes

            xml_box = obj.find("bndbox")
            xmin = int(xml_box.find("xmin").text)
            ymin = int(xml_box.find("ymin").text)
            xmax = int(xml_box.find("xmax").text)
            ymax = int(xml_box.find("ymax").text)

            # Convert to YOLO format
            x_center = ((xmin + xmax) / 2) / width
            y_center = ((ymin + ymax) / 2) / height
            w = (xmax - xmin) / width
            h = (ymax - ymin) / height

            f.write(f"0 {x_center:.6f} {y_center:.6f} {w:.6f} {h:.6f}\n")

def convert_all(anno_subdir, label_subdir):
    xml_files = os.listdir(anno_subdir)
    count = 0
    for xml in xml_files:
        xml_path = os.path.join(anno_subdir, xml)
        txt_name = os.path.splitext(xml)[0] + ".txt"
        txt_path = os.path.join(label_subdir, txt_name)
        convert_voc_to_yolo(xml_path, txt_path, (640, 640))  # you can use real image size if needed
        count += 1
    print(f"✅ Converted {count} files from {anno_subdir} → {label_subdir}")

# Convert both train and val
convert_all(f"{annotations_dir}/train", f"{labels_dir}/train")
convert_all(f"{annotations_dir}/val", f"{labels_dir}/val")


